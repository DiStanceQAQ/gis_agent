GIS_AGENT_APP_NAME=GIS Agent
GIS_AGENT_DEBUG=true
GIS_AGENT_API_PREFIX=/api/v1
GIS_AGENT_DATABASE_URL=postgresql+psycopg://gis_agent:gis_agent@localhost:5432/gis_agent
GIS_AGENT_STORAGE_ROOT=.data
GIS_AGENT_STORAGE_BACKEND=s3
GIS_AGENT_S3_ENDPOINT_URL=http://minio:9000
GIS_AGENT_S3_BUCKET=gis-agent
GIS_AGENT_S3_ACCESS_KEY_ID=minioadmin
GIS_AGENT_S3_SECRET_ACCESS_KEY=minioadmin
GIS_AGENT_S3_REGION=us-east-1
GIS_AGENT_S3_ADDRESSING_STYLE=path
GIS_AGENT_AOI_REGISTRY_PATH=
GIS_AGENT_EXECUTION_MODE=celery_agent
GIS_AGENT_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
GIS_AGENT_CELERY_BROKER_URL=redis://localhost:6379/0
GIS_AGENT_CELERY_RESULT_BACKEND=redis://localhost:6379/1
GIS_AGENT_CATALOG_STAC_URL=https://planetarycomputer.microsoft.com/api/stac/v1
GIS_AGENT_CATALOG_LIVE_SEARCH=true
GIS_AGENT_CATALOG_ALLOW_BASELINE_FALLBACK=true
GIS_AGENT_CATALOG_TIMEOUT_SECONDS=20
GIS_AGENT_CATALOG_PAGE_SIZE=50
GIS_AGENT_CATALOG_MAX_ITEMS=100
GIS_AGENT_REAL_PIPELINE_ENABLED=true
GIS_AGENT_REAL_PIPELINE_MAX_ITEMS=2
GIS_AGENT_REAL_PIPELINE_MAX_DIMENSION=256
GIS_AGENT_LLM_PROVIDER=openai_compatible
GIS_AGENT_LLM_BASE_URL=https://api.openai.com/v1
GIS_AGENT_LLM_API_KEY=
GIS_AGENT_LLM_MODEL=gpt-4o-mini
GIS_AGENT_LLM_TIMEOUT_SECONDS=60
GIS_AGENT_LLM_MAX_RETRIES=2
GIS_AGENT_LLM_TEMPERATURE=0.2
GIS_AGENT_LLM_PARSER_ENABLED=true
GIS_AGENT_LLM_PARSER_SCHEMA_RETRIES=2
GIS_AGENT_LLM_PARSER_LEGACY_FALLBACK=false
GIS_AGENT_LLM_PLANNER_ENABLED=true
GIS_AGENT_LLM_PLANNER_SCHEMA_RETRIES=2
GIS_AGENT_LLM_PLANNER_LEGACY_FALLBACK=false
GIS_AGENT_LLM_RECOMMENDATION_ENABLED=true
GIS_AGENT_LLM_RECOMMENDATION_SCHEMA_RETRIES=2
GIS_AGENT_LLM_RECOMMENDATION_LEGACY_FALLBACK=true
GIS_AGENT_LOCAL_FILES_ONLY_MODE=false
GIS_AGENT_AGENT_MAX_STEPS=12
GIS_AGENT_AGENT_MAX_TOOL_CALLS=24
GIS_AGENT_AGENT_RUNTIME_TIMEOUT_SECONDS=900
PIP_INDEX_URL=https://pypi.tuna.tsinghua.edu.cn/simple
PIP_TRUSTED_HOST=pypi.tuna.tsinghua.edu.cn
APT_MIRROR_HOST=mirrors.tuna.tsinghua.edu.cn
NPM_REGISTRY=https://registry.npmmirror.com
POSTGRES_IMAGE=docker.1panel.live/postgis/postgis:16-3.4
REDIS_IMAGE=docker.1panel.live/library/redis:7
MINIO_IMAGE=docker.1panel.live/minio/minio:latest
PYTHON_BASE_IMAGE=docker.1panel.live/library/python:3.12-slim
WEB_BASE_IMAGE=docker.1panel.live/library/node:24-alpine
